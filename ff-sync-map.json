{
  "sourceRepo": "../twilio-feature-factory",
  "targetRepo": ".",
  "syncState": "ff-sync-state.json",
  "description": "Maps twilio-feature-factory files to feature-factory targets. When patterns are battle-tested in the Twilio project, they sync here after adaptation (stripping platform-specific content).",
  "adaptationRules": {
    "strip-twilio-patterns": "Replace AC/SK/auth token patterns with config-driven ff_credential_patterns",
    "strip-twilio-services": "Remove Twilio service selection guides, voice/messaging/verify patterns",
    "strip-twilio-examples": "Replace Twilio code examples with generic equivalents",
    "strip-twilio-invariants": "Remove Architectural Invariants section (Twilio-only, lives in overlay)",
    "use-config-reader": "Replace hardcoded paths with ff_config/ff_config_array calls",
    "generalize-paths": "Replace functions/ with trackedDirectories, __tests__/unit/ with configurable test paths",
    "generalize-patterns": "Replace Twilio-specific patterns with generic equivalents",
    "generalize-language": "Remove Twilio/serverless/TwiML language, use generic terms"
  },
  "mappings": {
